# Copy to .env.production and fill in, OR (preferred) set these in the Vercel
# project's Environment Variables — Vercel values override anything committed.
#
# VITE_API_BASE must point at the backend Space root (no trailing slash).
VITE_API_BASE=https://<hf-user>-nyc-restaurant-api.hf.space

# Optional: Mapbox token for the Streets tile layer. Omit to fall back to Carto.
VITE_MAPBOX_TOKEN=
